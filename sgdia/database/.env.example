# ============================================================
# EASYDOC — Variables de entorno (ejemplo)
# Copiar a .env y ajustar valores reales
# ¡NO commitear .env con valores reales!
# ============================================================

# ── MongoDB ──────────────────────────────────────────────────
MONGO_ROOT_USER=sgdia_admin
MONGO_ROOT_PASSWORD=sgdia_secret
MONGO_DEV_PASSWORD=dev_password
MONGO1_HOST_PORT=27020
MONGO2_HOST_PORT=27021
MONGO3_HOST_PORT=27022

# Connection string para la aplicación (replica set)
MONGODB_URL=mongodb://sgdia_dev_user:dev_password@localhost:27020,localhost:27021,localhost:27022/sgdia_dev?replicaSet=rs0&authSource=sgdia_dev

# Para MongoDB Atlas en producción:
# MONGODB_URL=mongodb+srv://<user>:<pass>@cluster0.xxxx.mongodb.net/sgdia?retryWrites=true&w=majority

# ── Redis ─────────────────────────────────────────────────────
REDIS_PASSWORD=redis_secret
REDIS_HOST_PORT=6381
REDIS_URL=redis://:redis_secret@localhost:6381/0

# Namespaces Redis:
#   jwt_blacklist:<jti>        TTL = tiempo restante del JWT
#   session:<user_id>          TTL = 7d  (refresh token data)
#   cache:<resource>:<id>      TTL = 5m  (respuestas API)
#   notifications:<user_id>    TTL = 30d (notificaciones pendientes)

# ── MinIO / S3 ────────────────────────────────────────────────
MINIO_ROOT_USER=sgdia_minio
MINIO_ROOT_PASSWORD=minio_secret
S3_ENDPOINT=http://localhost:9010
MINIO_API_HOST_PORT=9010
MINIO_CONSOLE_HOST_PORT=9011
S3_ACCESS_KEY=sgdia_minio
S3_SECRET_KEY=minio_secret
S3_REGION=us-east-1

# Buckets
S3_BUCKET_DOCUMENTS=sgdia-documents
S3_BUCKET_EXPORTS=sgdia-exports
S3_BUCKET_AVATARS=sgdia-avatars
S3_BUCKET_TEMP=sgdia-temp

# Key structure: {org_id}/{module}/{year}/{month}/{file_id}
# Ejemplo: org_abc123/documents/2026/06/doc_xyz789.pdf

# ── Aplicación ────────────────────────────────────────────────
APP_ENV=development
SECRET_KEY=change_me_in_production_use_openssl_rand_hex_32
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
